{
  "expo": {
    "name": "Quiniela Mundial 2026",
    "slug": "quiniela-mundial-2026",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "quiniela",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a3a5c"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dragongolf.quiniela2026"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a3a5c"
      },
      "package": "com.dragongolf.quiniela2026",
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "name": "Quiniela Mundial 2026",
      "shortName": "Quiniela 2026",
      "description": "Llena tu quiniela del Mundial 2026",
      "backgroundColor": "#1a3a5c",
      "themeColor": "#1a3a5c",
      "display": "standalone",
      "startUrl": "/"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
